# ═══════════════════════════════════════════
# HEYGEN API — کلید و صدا حتماً باید پر بشن
# ═══════════════════════════════════════════
HEYGEN_API_KEY=your_api_key_here
HEYGEN_VOICE_ID=your_voice_id_here

# آواتار — یکی از این دو را پر کن:
#  ۱) یک آواتار تکی:
HEYGEN_AVATAR_ID=your_avatar_id_here
#  ۲) چند «لوک»/زاویه‌ی مختلف از آواتار خودت (با کاما جدا کن). توصیه‌شده:
#     سکانس‌ها بین این آواتارها می‌چرخند تا هر ویدیو زاویه/نمای متفاوت داشته باشد.
#     لیست آواتارها/لوک‌ها:  python scripts/list_looks.py
# HEYGEN_AVATAR_IDS=id1,id2,id3

# ═══════════════════════════════════════════
# اختیاری
# ═══════════════════════════════════════════

# حالت تست (کیفیت کمتر، بدون کسر اعتبار) — برای تولید نهایی false کن
HEYGEN_TEST_MODE=false

# نسبت تصویر — برای اینستاگرام عمودی 9:16 (پیش‌فرض). گزینه‌ها: 9:16 / 4:5 / 1:1 / 16:9
HEYGEN_VIDEO_RATIO=9:16

# آدرس API (اگه نیاز به تغییر داری)
# HEYGEN_API_BASE_URL=https://api.heygen.com

# لاگ
APP_LOG_LEVEL=INFO

# مسیرها
APP_DB_PATH=output/video_automation.db
APP_OUTPUT_DIR=output/videos
APP_DATA_DIR=data/content
